# Copy to .env and fill in. .env is git-ignored.

# --- Database (docker-compose defaults; override if deploying) ---
POSTGRES_USER=ri
POSTGRES_PASSWORD=ri_dev
POSTGRES_DB=research_intelligence
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# SQLAlchemy URL used by app code. Built from the above for convenience.
DATABASE_URL=postgresql+psycopg://ri:ri_dev@127.0.0.1:5432/research_intelligence

# --- Redis (arq queue + rate limits) ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- LLM providers (existing) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- API / Auth (M1b) ---
JWT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
EMAIL_ALLOWLIST=

# --- NotebookLM (M2) ---
NOTEBOOKLM_SESSION_FILE=/var/lib/notebooklm/session.json

# --- Object storage (M2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# --- Observability ---
SENTRY_DSN=
