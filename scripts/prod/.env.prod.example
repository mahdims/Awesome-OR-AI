# Copy to .env.prod and fill in. .env.prod is gitignored.
# Real DB credentials live on the box at /opt/researchmate/.env (chmod 600);
# the laptop never holds the prod DB password.

# SSH target — user@host or an alias from ~/.ssh/config.
PROD_HOST=mahdi@5.78.205.155

# Where the app repo is cloned on the box (created during M1b first deploy).
PROD_APP_DIR=/opt/researchmate/app

# Local Postgres URL used by prod-data-push.sh for pg_dump.
LOCAL_DATABASE_URL=postgresql+psycopg://ri:ri_dev@127.0.0.1:5432/research_intelligence
